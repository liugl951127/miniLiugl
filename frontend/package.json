{
  "name": "minimax-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "lint": "eslint . --ext .vue,.js,.jsx,.ts,.tsx --fix",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:unit": "vitest run --config vitest.config.js --reporter=verbose",
    "test:unit:watch": "vitest --config vitest.config.js --reporter=verbose",
    "test:unit:coverage": "vitest run --config vitest.config.js --coverage --reporter=verbose"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.7",
    "dayjs": "^1.11.10",
    "echarts": "^5.5.0",
    "element-plus": "^2.6.2",
    "highlight.js": "^11.9.0",
    "markdown-it": "^14.1.0",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^3.2.1",
    "qrcode": "^1.5.4",
    "vant": "^4.9.24",
    "vue": "^3.4.21",
    "vue-echarts": "^7.0.3",
    "vue-i18n": "^11.4.6",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.6",
    "sass": "^1.71.1",
    "terser": "^5.48.0",
    "unplugin-auto-import": "^0.17.5",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.1.4",
    "vitest": "^4.1.9"
  }
}