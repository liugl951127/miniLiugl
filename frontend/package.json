{
  "name": "minimax-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "browserslist": [
    "Chrome >= 63",
    "Edge >= 79",
    "Firefox >= 60",
    "Safari >= 12",
    "Opera >= 50",
    "iOS >= 12",
    "Android >= 8",
    "not dead",
    "not IE 11"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "lint": "eslint . --ext .vue,.js,.jsx,.ts,.tsx --fix",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest --watch",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "cap:sync": "cap sync",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android",
    "cap:add:ios": "cap add ios",
    "cap:add:android": "cap add android",
    "cap:copy": "cap copy",
    "cap:build:ios": "cap copy ios && cap open ios",
    "cap:build:android": "cap copy android && cap open android"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.7",
    "dayjs": "^1.11.10",
    "echarts": "^5.5.0",
    "element-plus": "^2.6.2",
    "highlight.js": "^11.9.0",
    "markdown-it": "^14.1.0",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^3.2.1",
    "qrcode": "^1.5.4",
    "vant": "^4.9.24",
    "vue": "^3.4.21",
    "vue-echarts": "^7.0.3",
    "vue-i18n": "^11.4.6",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/keyboard": "^6.0.4",
    "@capacitor/network": "^6.0.4",
    "@capacitor/preferences": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.9",
    "jsdom": "^29.1.1",
    "sass": "^1.71.1",
    "terser": "^5.48.0",
    "unplugin-auto-import": "^0.17.5",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.1.4",
    "vitest": "^4.1.9"
  }
}
