# =============================================================
# V5.3: 前端开发环境配置
# =============================================================

# Vite 端口 (默认 3000)
VITE_PORT=3000

# 是否走 gateway (默认 true)
# true  → 走 http://localhost:8080 (gateway 统一入口)
# false → 直连各微服务端口 (开发调试用)
VITE_USE_GATEWAY=true

# Gateway 地址 (开发环境)
VITE_GATEWAY_URL=http://localhost:8080

# 直连模式下的基础 URL (一般用不到)
VITE_API_BASE=http://localhost:8080

# 公开站点 URL (生产)
VITE_PUBLIC_URL=http://localhost:3000
