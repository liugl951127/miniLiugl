<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.minimax.agent.mapper.CollabMemberMapper">
    <resultMap id="BaseResultMap" type="com.minimax.agent.entity.CollabMember">
        <id property="id" column="id"/>
        <result property="collabId" column="collab_id"/>
        <result property="userId" column="user_id"/>
        <result property="role" column="role"/>
        <result property="joinedAt" column="joined_at"/>
        <result property="lastActiveAt" column="last_active_at"/>
    </resultMap>

    <select id="selectByUser" resultMap="BaseResultMap">
        SELECT * FROM collab_member
        WHERE collab_id = #{collabId} AND user_id = #{userId}
        LIMIT 1
    </select>
</mapper>
