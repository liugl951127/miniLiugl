<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.minimax.agent.mapper.CollabSessionMapper">
    <resultMap id="BaseResultMap" type="com.minimax.agent.entity.CollabSession">
        <id property="id" column="id"/>
        <result property="sessionId" column="session_id"/>
        <result property="ownerId" column="owner_id"/>
        <result property="title" column="title"/>
        <result property="maxUsers" column="max_users"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <select id="selectByOwner" resultMap="BaseResultMap">
        SELECT * FROM collab_session
        WHERE owner_id = #{ownerId} AND deleted = 0
        ORDER BY updated_at DESC
    </select>

    <select id="selectBySessionId" resultMap="BaseResultMap">
        SELECT * FROM collab_session
        WHERE session_id = #{sessionId} AND deleted = 0
        LIMIT 1
    </select>
</mapper>
