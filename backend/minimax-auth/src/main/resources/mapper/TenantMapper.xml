<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.minimax.auth.mapper.TenantMapper">
    <resultMap id="tenantMap" type="com.minimax.auth.entity.Tenant">
        <id property="id" column="id"/>
        <result property="code" column="code"/>
        <result property="name" column="name"/>
        <result property="plan" column="plan"/>
        <result property="status" column="status"/>
        <result property="maxUsers" column="max_users"/>
        <result property="maxModels" column="max_models"/>
        <result property="qpsLimit" column="qps_limit"/>
        <result property="monthlyQuota" column="monthly_quota"/>
        <result property="usedQuota" column="used_quota"/>
        <result property="expireAt" column="expire_at"/>
        <result property="contactEmail" column="contact_email"/>
        <result property="contactPhone" column="contact_phone"/>
        <result property="remark" column="remark"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <select id="selectByCode" resultMap="tenantMap">
        SELECT * FROM tenant WHERE code = #{code} AND deleted = 0 LIMIT 1
    </select>

    <select id="selectByOwner" resultMap="tenantMap">
        SELECT * FROM tenant WHERE deleted = 0 ORDER BY id
    </select>
</mapper>
