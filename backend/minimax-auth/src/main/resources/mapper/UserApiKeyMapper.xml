<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.minimax.auth.mapper.UserApiKeyMapper">

    <resultMap id="apiKeyMap" type="com.minimax.auth.entity.UserApiKey">
        <id     property="id"            column="id"/>
        <result property="userId"        column="user_id"/>
        <result property="name"          column="name"/>
        <result property="keyHash"       column="key_hash"/>
        <result property="keyPrefix"      column="key_prefix"/>
        <result property="scopes"         column="scopes"/>
        <result property="expiresAt"     column="expires_at"/>
        <result property="lastUsedAt"   column="last_used_at"/>
        <result property="useCount"      column="use_count"/>
        <result property="enabled"        column="enabled"/>
        <result property="createdAt"     column="created_at"/>
        <result property="updatedAt"     column="updated_at"/>
        <result property="deleted"        column="deleted"/>
    </resultMap>

    <select id="selectByUserId" resultMap="apiKeyMap">
        SELECT * FROM user_api_key
        WHERE user_id = #{userId} AND deleted = 0
        ORDER BY created_at DESC
    </select>

    <select id="selectByKeyHash" resultMap="apiKeyMap">
        SELECT * FROM user_api_key
        WHERE key_hash = #{keyHash} AND deleted = 0 AND enabled = 1
        LIMIT 1
    </select>

    <update id="incrementUseCount">
        UPDATE user_api_key
        SET use_count = use_count + 1, last_used_at = NOW()
        WHERE id = #{id}
    </update>

</mapper>
