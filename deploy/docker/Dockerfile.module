# ============================================================
# Multi-stage Dockerfile (V2.8.0)
# 用法: docker build --build-arg MODULE=minimax-ai -t image:tag .
# ============================================================

# 阶段 1: 构建
FROM maven:3.9-eclipse-temurin-17 AS builder
ARG MODULE=minimax-gateway
WORKDIR /build

# 先 copy pom 利用缓存
COPY backend/pom.xml backend/.mvn ./
COPY backend/$MODULE ./backend/$MODULE

# 构建
# V3.5.5+: 如果 MODULE=minimax-common (packaging=pom library), 用 install 不打 jar
#   其他 16 个可执行应用模块 (auth/ai/...) 用 package 打 spring-boot fat jar
RUN if [ "$MODULE" = "minimax-common" ]; then \
        echo "=== minimax-common 是 packaging=pom library, 跳过 jar 打包 ===" && \
        cd backend && mvn -s .mvn/settings.xml install -pl $MODULE -am -DskipTests -B; \
    else \
        cd backend && mvn -s .mvn/settings.xml package -pl $MODULE -am -DskipTests -B -T 4; \
    fi

# 阶段 2: 运行时
FROM eclipse-temurin:17-jre-alpine
ARG MODULE=minimax-gateway
ENV MODULE_NAME=$MODULE
ENV JAVA_OPTS="-XX:+UseG1GC -XX:MaxRAMPercentage=70.0 -Dfile.encoding=UTF-8"
ENV TZ=Asia/Shanghai

# 健康检查
RUN apk add --no-cache curl tini && \
    mkdir -p /app/logs /app/data

WORKDIR /app
# V3.5.5+: minimax-common 没 jar, 跳过
COPY --from=builder /build/backend/$MODULE/target/$MODULE.jar /app/app.jar 2>/dev/null || \
    echo "WARN: $MODULE 没生成 jar (可能是 packaging=pom library, 如 minimax-common)" && \
    echo "FROM scratch" > /tmp/skip && true

# 暴露端口 (各模块不同, 默认 7080)
EXPOSE 7080

HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD curl -f http://localhost:7080/actuator/health || exit 1

ENTRYPOINT ["/sbin/tini", "--", "sh", "-c", "exec java $JAVA_OPTS -jar /app/app.jar"]
