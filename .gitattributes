# =============================================================
# Git attributes - 强制所有文本文件用 LF 换行符 (V3.5.5+)
# =============================================================
# 解决问题: Windows 用户 clone 时 core.autocrlf=true 会把 LF → CRLF
#           导致 /usr/bin/env: 'bash\r' 错误
#
# 关键: *.sh 必须用 LF (CRLF 解释器会找不到 bash)
#       *.conf / *.yml 也用 LF (nginx/yaml 严格)
# =============================================================

# 文本文件: 自动转 LF
* text=auto eol=lf

# Shell 脚本: 强制 LF (不能 CRLF)
*.sh  eol=lf
*.bash eol=lf

# Docker 配置
Dockerfile eol=lf
*.dockerfile eol=lf

# YML / YAML
*.yml  eol=lf
*.yaml eol=lf

# nginx
*.conf eol=lf

# Java / SQL / JS / Vue / CSS (代码都 LF)
*.java  eol=lf
*.sql   eol=lf
*.js    eol=lf
*.ts    eol=lf
*.vue   eol=lf
*.css   eol=lf
*.html  eol=lf
*.xml   eol=lf
*.md    eol=lf
*.json  eol=lf

# 二进制文件: 不要处理
*.jar  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.tar  binary
*.gz   binary
