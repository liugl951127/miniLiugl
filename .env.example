# =============================================================
# MiniMax Platform - 环境变量模板 (V2.2)
#
# 复制并修改:
#   cp .env.example .env
#   vim .env
#
# 加载到 docker compose:
#   docker compose --env-file .env up -d
# =============================================================

# ===== 基础配置 =====
COMPOSE_PROJECT_NAME=minimax
DATA_ROOT=/opt/minimax/data

# ===== 镜像版本 =====
IMAGE_TAG=latest

# ===== MySQL (统一密码) =====
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=minimax_platform
MYSQL_PORT=3306

# ===== Redis (统一密码) =====
REDIS_PASSWORD=minimax_redis_2024
REDIS_PORT=6379

# ===== Nacos =====
NACOS_USER=nacos
NACOS_PASSWORD=nacos
NACOS_PORT=8848

# ===== OpenTelemetry Collector =====
OTEL_COLLECTOR_PORT_GRPC=4317
OTEL_COLLECTOR_PORT_HTTP=4318
OTEL_COLLECTOR_PORT_PROMETHEUS=8888

# ===== JWT 统一密钥 (HS256 / 64 字符 hex / 256 bit) =====
# 规范: openssl rand -hex 32 生成
# 用途: 跨 16 个微服务统一 token 签名
# 生成: ./deploy-simple/generate-jwt-secret.sh --apply
MINIMAX_JWT_SECRET=a9b33d29b5e2728699fc02fe5f1aad70d2a0eb95c4313b786005573f6b913478
# 通用加密密钥 (AES / SM4 / 签名 / IV 派生)
MINIMAX_COMMON_SECRET=a9b33d29b5e2728699fc02fe5f1aad70d2a0eb95c4313b786005573f6b913478

# ===== MinIO (文件存储, 可选) =====
MINIO_ROOT_USER=minimax_admin
MINIO_ROOT_PASSWORD=minimax_minio_2024
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ===== 业务配置 =====
# 域名 (生产环境)
MINIMAX_DOMAIN=liugeliang.com

# 管理员邮箱 (Let's Encrypt 用)
ADMIN_EMAIL=admin@liugeliang.com

# 时区
TZ=Asia/Shanghai

# ===== 内存限制 (可选, 默认值在 docker-compose.yml) =====
# GATEWAY_MEMORY=512M
# AUTH_MEMORY=384M
# SERVICE_MEMORY=256M

# ===== JVM 调优 (可选) =====
# JAVA_OPTS=-XX:MaxRAMPercentage=70.0 -XX:+UseG1GC

# ===== 调试模式 =====
# SPRING_PROFILES_ACTIVE=dev
# LOGGING_LEVEL=DEBUG
